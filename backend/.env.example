# PostgreSQL connection (Neon, Supabase, or local)
# Get from: Neon Console → Connection string, or Supabase → Project Settings → Database
DATABASE_URL=postgresql://neondb_owner:npg_Y9nuwzX5piHN@ep-silent-heart-a1v754t6-pooler.ap-southeast-1.aws.neon.tech/neondb?sslmode=require&channel_binding=require

# Limit data loaded from DB to last N years (default: 3). Set to 0 to load all.
# Lower = less RAM used. 3 years covers all current FY data.
EGRESS_MAX_YEARS=3

# Optional: server port (default 8080; Render sets PORT)
# PORT=8000

# Optional: default role for users (viewer, manager, admin)
# ELETTRO_DEFAULT_ROLE=viewer

# Public signup: set to true to allow anyone to create an account. Default=false — only admin adds users via seed script.
# SIGNUP_ENABLED=true
